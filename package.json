{
  "name": "my-portfolio",
  "version": "1.0.0",
  "description": "Portfolio de Céline Poloni, développeuse web full-stack junior",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "validate": "biome ci . && npm run build",
    "dev": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --watch",
    "build": "tailwindcss -i ./assets/css/input.css -o ./assets/css/output.css --minify",
    "serve": "npx serve . -l 3000",
    "start": "node index.js",
    "start:dev": "npm run build && npm start",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Celine-Poloni/my-portfolio.git"
  },
  "keywords": [
    "portfolio",
    "web developer"
  ],
  "author": "Celine",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Celine-Poloni/my-portfolio/issues"
  },
  "homepage": "https://github.com/Celine-Poloni/my-portfolio#readme",
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@tailwindcss/cli": "^4.1.17",
    "tailwindcss": "^4.1.17"
  },
  "dependencies": {}
}
