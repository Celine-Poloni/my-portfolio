{
  "name": "my-portfolio",
  "version": "1.0.0",
  "description": "Portfolio de Céline Poloni, développeuse web full-stack junior",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write . vitest.config.ts",
    "format:check": "biome format . vitest.config.ts",
    "validate": "biome ci . && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node index.js",
    "start:dev": "npm run build && npm start",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Celine-Poloni/my-portfolio.git"
  },
  "keywords": [
    "portfolio",
    "web developer"
  ],
  "author": "Celine",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Celine-Poloni/my-portfolio/issues"
  },
  "homepage": "https://github.com/Celine-Poloni/my-portfolio#readme",
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.17",
    "flowbite": "^4.0.1",
    "tailwindcss": "^4.1.17"
  }
}
