{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["ES2024"],
    "module": "es2022",
    "rootDir": "./",
    "moduleResolution": "bundler",
    "baseUrl": "./",
    "paths": {},
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "types": ["vitest/globals"]
  },
  "include": ["**/*", "**/*.test.ts", "vitest.config.js"],
  "exclude": ["node_modules", "tests/dist", "build", "coverage", "tmp"]
}
